#!/usr/bin/env bash
# gtheme — Ghostty theme switcher
# https://github.com/UnionPAC/gtheme

set -euo pipefail

VERSION="0.1.0"
THEMES_DIR="${GTHEME_DIR:-$HOME/.config/ghostty/themes}"
ACTIVE="$THEMES_DIR/active.conf"
GHOSTTY_CONFIG="$HOME/.config/ghostty/config"
REGISTRY_BASE="https://raw.githubusercontent.com/UnionPAC/gtheme/main/registry"
BINARY_URL="https://raw.githubusercontent.com/UnionPAC/gtheme/main/bin/gtheme"
VERSION_URL="https://raw.githubusercontent.com/UnionPAC/gtheme/main/VERSION"
UPDATE_CHECK_FILE="$THEMES_DIR/.gtheme_last_check"
UPDATE_NOTICE_FILE="$THEMES_DIR/.gtheme_updated"

# ── helpers ──────────────────────────────────────────────────────────────────

get_font() {
  grep -m1 '^font-family' "$1" 2>/dev/null | sed 's/font-family *= *//'
}

brew_cask_name() {
  case "$1" in
    "JetBrainsMono Nerd Font")  echo "font-jetbrains-mono-nerd-font" ;;
    "CaskaydiaCove Nerd Font")  echo "font-caskaydia-cove-nerd-font" ;;
    "FiraCode Nerd Font")       echo "font-fira-code-nerd-font" ;;
    "Hack Nerd Font")           echo "font-hack-nerd-font" ;;
    *)                          echo "" ;;
  esac
}

active_name() {
  if [[ -L "$ACTIVE" ]]; then
    basename "$(readlink "$ACTIVE")" .conf
  fi
}

font_installed() {
  local name="$1"
  local stem="${name%% Nerd*}"
  local pattern="${stem// /}"
  find \
    "$HOME/Library/Fonts" \
    "/Library/Fonts" \
    "$HOME/.local/share/fonts" \
    "/usr/share/fonts" \
    "/usr/local/share/fonts" \
    -maxdepth 3 -iname "*${pattern}*" 2>/dev/null | grep -q .
}

require_cmd() {
  command -v "$1" &>/dev/null || { echo "Error: '$1' is required but not installed."; exit 1; }
}

show_update_notice() {
  if [[ -f "$UPDATE_NOTICE_FILE" ]]; then
    local version
    version=$(cat "$UPDATE_NOTICE_FILE")
    echo "✓ gtheme updated to v$version"
    rm -f "$UPDATE_NOTICE_FILE"
  fi
}

auto_update() {
  # Skip if running from a symlink (developer mode)
  local self
  self="$(command -v gtheme 2>/dev/null || echo "$0")"
  [[ -L "$self" ]] && return

  # Only check once per day
  if [[ -f "$UPDATE_CHECK_FILE" ]]; then
    local last_check now
    last_check=$(cat "$UPDATE_CHECK_FILE")
    now=$(date +%s)
    (( now - last_check < 86400 )) && return
  fi

  # Background: check version, download if newer
  (
    date +%s > "$UPDATE_CHECK_FILE"
    local latest
    latest=$(curl -fsSL --max-time 3 "$VERSION_URL" 2>/dev/null | tr -d '[:space:]')
    [[ -z "$latest" || "$latest" == "$VERSION" ]] && exit 0
    local tmp
    tmp=$(mktemp)
    if curl -fsSL --max-time 10 "$BINARY_URL" -o "$tmp" 2>/dev/null; then
      chmod +x "$tmp"
      mv "$tmp" "$self"
      echo "$latest" > "$UPDATE_NOTICE_FILE"
    else
      rm -f "$tmp"
    fi
  ) &>/dev/null &
  disown
}

cmd_update() {
  local self
  self="$(command -v gtheme 2>/dev/null || echo "$0")"
  if [[ -L "$self" ]]; then
    echo "Running in developer mode (symlink detected) — skipping update."
    exit 0
  fi
  echo "Checking for updates..."
  local latest
  latest=$(curl -fsSL --max-time 5 "$VERSION_URL" 2>/dev/null | tr -d '[:space:]')
  if [[ -z "$latest" ]]; then
    echo "Could not reach update server. Check your connection."
    exit 1
  fi
  if [[ "$latest" == "$VERSION" ]]; then
    echo "Already up to date (v$VERSION)."
    exit 0
  fi
  echo "Updating v$VERSION → v$latest..."
  local tmp
  tmp=$(mktemp)
  if curl -fsSL --max-time 10 "$BINARY_URL" -o "$tmp" 2>/dev/null; then
    chmod +x "$tmp"
    mv "$tmp" "$self"
    echo "Done. gtheme is now v$latest."
  else
    rm -f "$tmp"
    echo "Update failed. Try again or re-run the installer."
    exit 1
  fi
}

# ── commands ─────────────────────────────────────────────────────────────────

cmd_list() {
  local found=0
  for f in "$THEMES_DIR"/*.conf; do
    [[ -e "$f" ]] || continue
    name="$(basename "$f" .conf)"
    [[ "$name" == "active" ]] && continue
    found=1
  done

  if [[ "$found" -eq 0 ]]; then
    echo "No themes installed."
    echo "Browse the community registry: gtheme search"
    return
  fi

  echo "Installed themes:"
  echo ""
  for f in "$THEMES_DIR"/*.conf; do
    name="$(basename "$f" .conf)"
    [[ "$name" == "active" ]] && continue
    if [[ "$(active_name)" == "$name" ]]; then
      echo "  * $name  (active)"
    else
      echo "    $name"
    fi
  done
}

cmd_switch() {
  local name="$1"
  local target="$THEMES_DIR/$name.conf"

  if [[ ! -f "$target" ]]; then
    echo "Error: theme '$name' not found locally."
    echo "Try: gtheme search $name"
    exit 1
  fi

  if [[ "$(active_name)" == "$name" ]]; then
    echo "Already using: $name"
    exit 0
  fi

  ln -sf "$target" "$ACTIVE"

  local font cask
  font="$(get_font "$target")"
  cask="$(brew_cask_name "$font")"

  echo "Switched to: $name"
  if [[ -n "$font" ]] && ! font_installed "$font"; then
    [[ -n "$cask" ]] && echo "⚠  Font not installed: brew install --cask $cask"
  fi
  echo "Reload Ghostty: cmd + shift + ,"
}

cmd_search() {
  require_cmd curl
  local query="${1:-}"
  local index
  index="$(curl -fsSL --max-time 5 "$REGISTRY_BASE/index.json" 2>/dev/null)"

  if [[ -z "$index" ]]; then
    echo "Could not reach registry. Check your connection."
    exit 1
  fi

  if ! command -v python3 &>/dev/null; then
    # fallback: basic grep output
    echo "Tip: install python3 for richer search output."
    echo ""
    echo "$index" | grep -o '"name":"[^"]*"\|"description":"[^"]*"' \
      | sed 's/"name":"//;s/"description":"//;s/"//' \
      | grep -i "${query:-.}" || echo "No themes found matching '$query'."
    return
  fi

  echo "$index" | GTHEME_QUERY="$query" python3 -c '
import json, sys, os

index = json.loads(sys.stdin.read())
query = os.environ.get("GTHEME_QUERY", "").lower()

results = [
    t for t in index
    if not query
    or query in t["name"]
    or query in t.get("description", "").lower()
    or any(query in tag for tag in t.get("tags", []))
    or query in t.get("author", "").lower()
]

if not results:
    print(f"No themes found matching \"{query}\".")
    sys.exit(0)

print(f"{len(results)} theme{\"s\" if len(results) != 1 else \"\"} found:\n")
for t in results:
    tags = "  [" + ", ".join(t.get("tags", [])) + "]" if t.get("tags") else ""
    print(f"  {t[\"name\"]}{tags}")
    print(f"  {t.get(\"description\", \"\")}")
    print(f"  by @{t.get(\"author\", \"\")}  ·  font: {t.get(\"font\", \"\")}")
    print(f"  gtheme add {t[\"name\"]}")
    print()
'
}

cmd_add() {
  require_cmd curl
  local name="$1"
  local target="$THEMES_DIR/$name.conf"

  local reserved="list search add remove update submit version help"
  for word in $reserved; do
    if [[ "$name" == "$word" ]]; then
      echo "Error: '$name' is a reserved command name and cannot be used as a theme name."
      exit 1
    fi
  done

  if [[ -f "$target" ]]; then
    echo "Theme '$name' is already installed."
    exit 0
  fi

  echo "Fetching '$name' from registry..."
  local url="$REGISTRY_BASE/themes/$name.conf"

  if ! curl -fsSL "$url" -o "$target" 2>/dev/null; then
    rm -f "$target"
    echo "Error: theme '$name' not found in registry."
    echo "Browse community themes: https://unionpac.github.io/gtheme"
    exit 1
  fi

  local font cask
  font="$(get_font "$target")"
  cask="$(brew_cask_name "$font")"

  echo "Installed: $name"
  if [[ -n "$font" ]] && ! font_installed "$font"; then
    [[ -n "$cask" ]] && echo "⚠  Font not installed: brew install --cask $cask"
  fi
  echo "Activate with: gtheme $name"
}

cmd_remove() {
  local name="$1"
  local target="$THEMES_DIR/$name.conf"

  if [[ ! -f "$target" ]]; then
    echo "Theme '$name' is not installed."
    exit 1
  fi

  if [[ "$(active_name)" == "$name" ]]; then
    echo "Error: '$name' is currently active. Switch to another theme first."
    exit 1
  fi

  rm "$target"
  echo "Removed: $name"
}

cmd_version() {
  echo "gtheme v$VERSION"
}

cmd_submit() {
  local url="https://github.com/UnionPAC/gtheme/issues/new?template=submit-theme.yml"
  echo "Opening theme submission form in your browser..."
  echo ""
  echo "Fill out the form and we'll add your theme to the registry."
  echo "URL: $url"
  echo ""
  if command -v open &>/dev/null; then
    open "$url"
  elif command -v xdg-open &>/dev/null; then
    xdg-open "$url"
  else
    echo "Open the URL above in your browser to submit."
  fi
}

cmd_help() {
  cat <<EOF
gtheme — Ghostty theme switcher

Usage:
  gtheme list                  List installed themes
  gtheme <name>                Switch to a theme
  gtheme search [query]        Search the community registry
  gtheme add <name>            Install a theme from the registry
  gtheme remove <name>         Remove an installed theme
  gtheme update                Update gtheme to the latest version
  gtheme submit                Share your theme with the community
  gtheme version               Show the current version
  gtheme help                  Show this help

Reload Ghostty after switching: cmd + shift + ,
Browse community themes: https://unionpac.github.io/gtheme
EOF
}

# ── startup ──────────────────────────────────────────────────────────────────

# Warn if active symlink points to a deleted theme
if [[ -L "$ACTIVE" && ! -f "$ACTIVE" ]]; then
  echo "⚠  Active theme is missing — run 'gtheme list' and switch to a valid theme."
fi

show_update_notice
auto_update

# ── router ───────────────────────────────────────────────────────────────────

case "${1:-}" in
  list)              cmd_list ;;
  search)            cmd_search "${2:-}" ;;
  add)               [[ -z "${2:-}" ]] && { echo "Usage: gtheme add <name>"; exit 1; }; cmd_add "$2" ;;
  remove|rm)         [[ -z "${2:-}" ]] && { echo "Usage: gtheme remove <name>"; exit 1; }; cmd_remove "$2" ;;
  update)            cmd_update ;;
  version|--version) cmd_version ;;
  submit)            cmd_submit ;;
  help|--help|-h)    cmd_help ;;
  "")                cmd_help ;;
  *)                 cmd_switch "$1" ;;
esac
